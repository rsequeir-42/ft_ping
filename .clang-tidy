# clang-tidy configuration for ft_ping.
# Wide families enabled; a few checks excluded because they don't fit low-level C
# (ICMP type constants are not "magic numbers", short names like fd/n/i are clear
# in context, easily-swappable-parameters is noisy on C signatures, and the
# Annex K *_s functions that insecureAPI asks for are absent from glibc).

Checks: >
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  misc-*,
  performance-*,
  portability-*,
  readability-*,
  -readability-magic-numbers,
  -readability-identifier-length,
  -bugprone-easily-swappable-parameters,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling

WarningsAsErrors:   '*'
HeaderFilterRegex:  '^(src|include)/.*\.h$'
FormatStyle:        file
