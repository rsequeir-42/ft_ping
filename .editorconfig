# Editor defaults for ft_ping. .clang-format remains the source of truth for the
# code style; this file keeps the editor consistent at typing time. The
# [Makefile] section forces tab identation -- recipes break otherwise.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab