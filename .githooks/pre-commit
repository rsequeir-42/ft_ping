#!/bin/sh
# pre-commit: verify formatting and lint the staged C sources before they enter
# history. Bypassable with 'git commit --no-verify'; CI is the real gate.
set -eu

CLANG_FORMAT="${CLANG_FORMAT:-clang-format-19}"
CLANG_TIDY="${CLANG_TIDY:-clang-tidy-19}"

# Staged sources/headers (Added, Copied, Modified).
files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(c|h)$' || true)
[ -z "$files" ] && exit 0

# 1. Formatting: verify only, never rewrite inside the hook.
printf '%s\n' "$files" | xargs "$CLANG_FORMAT" --dry-run --Werror

# 2. clang-tidy on staged .c files (headers covered via HeaderFilterRegex). Needs
#    the compilation database; if absent, warn but do not block -- pre-push and
#    CI run the full 'make check' anyway.
c_files=$(printf '%s\n' "$files" | grep -E '\.c$' || true)
if [ -n "$c_files" ]; then
    if [ -f compile_commands.json ]; then
        printf '%s\n' "$c_files" | xargs "$CLANG_TIDY" -p .
    else
        echo "pre-commit: compile_commands.json missing, skipping clang-tidy (run 'make compile-db')" >&2
    fi
fi

exit 0